<Window x:Class="StickerApp.HotkeyRecorderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Запись хоткея"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Width="300" Height="165"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.65" BlurRadius="28" ShadowDepth="8"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title + cancel -->
            <Grid Grid.Row="0">
                <TextBlock Text="Запись хоткея"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="13" FontWeight="SemiBold"
                           FontFamily="Segoe UI Variable, Segoe UI"
                           VerticalAlignment="Center"/>
                <Button Content="✕" Width="22" Height="22"
                        HorizontalAlignment="Right"
                        Foreground="{StaticResource SubtextBrush}"
                        Background="Transparent" BorderThickness="0"
                        FontSize="11" Cursor="Hand"
                        Click="OnCancel">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DestroyBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Hint -->
            <TextBlock Grid.Row="2"
                       Text="Нажмите комбинацию клавиш или Esc для отмены"
                       Foreground="{StaticResource SubtextBrush}"
                       FontSize="11"
                       FontFamily="Segoe UI Variable, Segoe UI"
                       TextWrapping="Wrap"/>

            <!-- Live combo display -->
            <TextBlock Grid.Row="4"
                       x:Name="RecordedText"
                       Text="—"
                       Foreground="{StaticResource TextBrush}"
                       FontSize="17" FontWeight="Bold"
                       FontFamily="Segoe UI Variable, Segoe UI"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>
    </Border>
</Window>
