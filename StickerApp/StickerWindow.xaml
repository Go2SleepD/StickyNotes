<Window x:Class="StickerApp.StickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="260" Height="260"
        MinWidth="180" MinHeight="150">

    <!-- Outer grid: alpha=1 invisible border lets WM_NCHITTEST fire for resize; enabled after spawn -->
    <Grid x:Name="OuterGrid" Background="Transparent">

        <!-- Ambient (far/diffuse) shadow layer — sits behind StickerBorder -->
        <Border x:Name="AmbientShadow"
                Margin="20"
                CornerRadius="10"
                Background="Transparent">
            <Border.CacheMode>
                <BitmapCache EnableClearType="False" SnapsToDevicePixels="False"/>
            </Border.CacheMode>
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.18"
                                  BlurRadius="56" ShadowDepth="22" Direction="300"/>
            </Border.Effect>
        </Border>

        <!-- Main sticker surface -->
        <Border x:Name="StickerBorder"
                Margin="20"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <Border.CacheMode>
                <BitmapCache EnableClearType="False" SnapsToDevicePixels="False"/>
            </Border.CacheMode>
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.50"
                                  BlurRadius="12" ShadowDepth="5" Direction="300"/>
            </Border.Effect>

            <Grid Background="Transparent">

                <!-- ── Task list ─────────────────────────────────────────── -->
                <StackPanel x:Name="ContentPanel" Margin="0,4,0,24" Background="Transparent">

                        <!-- Drawer container -->
                        <Border Margin="8,4,8,4" CornerRadius="7"
                                Background="#0E0E16"
                                BorderBrush="#21212F" BorderThickness="1">
                            <Grid>

                                <!-- Inner depth shadow at top -->
                                <Border CornerRadius="6,6,0,0" Height="14"
                                        VerticalAlignment="Top" IsHitTestVisible="False">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#35000000" Offset="0"/>
                                            <GradientStop Color="#00000000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <!-- Drawer pull handle -->
                                <Border HorizontalAlignment="Center" VerticalAlignment="Top"
                                        Width="26" Height="3" CornerRadius="1.5"
                                        Margin="0,5,0,0" IsHitTestVisible="False"
                                        Background="#2A2A3C"/>

                                <StackPanel Margin="5,14,5,5">

                        <ItemsControl x:Name="TaskList" Background="Transparent">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Task card — same surface as the sticker itself -->
                                    <Border Margin="0,2" CornerRadius="5"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1">
                                    <Grid x:Name="TaskRow" MinHeight="26" Margin="6,2,2,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="18"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding Done, Mode=TwoWay}"
                                                  VerticalAlignment="Center"
                                                  Checked="OnTaskCheckedChanged"
                                                  Unchecked="OnTaskCheckedChanged">
                                            <CheckBox.Style>
                                                <Style TargetType="CheckBox">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="CheckBox">
                                                                <Border x:Name="Box" Width="14" Height="14" CornerRadius="3"
                                                                        BorderThickness="1.5"
                                                                        BorderBrush="{StaticResource SubtextBrush}"
                                                                        Background="Transparent">
                                                                    <Path x:Name="Chk"
                                                                          Data="M2,7 L5,10 L12,3"
                                                                          Stroke="{DynamicResource DoneMarkBrush}"
                                                                          StrokeThickness="1.8"
                                                                          Visibility="Collapsed"
                                                                          StrokeStartLineCap="Round"
                                                                          StrokeEndLineCap="Round"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsChecked" Value="True">
                                                                        <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource DoneMarkBrush}"/>
                                                                        <Setter TargetName="Chk" Property="Visibility" Value="Visible"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </CheckBox.Style>
                                        </CheckBox>

                                        <!-- Text + animated strikethrough overlay -->
                                        <Grid Grid.Column="1">
                                            <TextBlock x:Name="TaskText"
                                                       Text="{Binding Text}"
                                                       VerticalAlignment="Center"
                                                       FontSize="12.5"
                                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                                                       Margin="5,0,3,0"
                                                       TextWrapping="Wrap">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="#E2E2E8"/>
                                                </TextBlock.Foreground>
                                            </TextBlock>

                                            <!-- Inline edit display (visible only when IsEditing) -->
                                            <TextBlock x:Name="EditDisplay"
                                                       Visibility="Collapsed"
                                                       Text="{Binding DisplayText}"
                                                       VerticalAlignment="Center"
                                                       FontSize="12.5"
                                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                                                       Margin="5,0,3,0"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextBrush}"/>

                                            <!-- Strike line drawn left-to-right via ScaleX animation -->
                                            <Rectangle x:Name="StrikeLine"
                                                       Height="1.5"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Stretch"
                                                       Margin="5,0,3,0"
                                                       Fill="{DynamicResource DoneMarkBrush}"
                                                       IsHitTestVisible="False"
                                                       RenderTransformOrigin="0,0.5">
                                                <Rectangle.RenderTransform>
                                                    <ScaleTransform x:Name="StrikeScaleT" ScaleX="0"/>
                                                </Rectangle.RenderTransform>
                                            </Rectangle>
                                        </Grid>

                                        <Button Grid.Column="2" Content="×"
                                                Width="16" Height="16"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource SubtextBrush}"
                                                Background="Transparent" BorderThickness="0"
                                                FontSize="13" Cursor="Hand"
                                                Tag="{Binding Id}"
                                                Click="OnDeleteTaskClick">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Opacity" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="Transparent">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                         To="1" Duration="0:0:0.1"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                         To="0" Duration="0:0:0.15"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Done}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ColorAnimation
                                                            Storyboard.TargetName="TaskText"
                                                            Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                                            To="#6B7280" Duration="0:0:0.25"/>
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="StrikeScaleT"
                                                            Storyboard.TargetProperty="ScaleX"
                                                            To="1" Duration="0:0:0.32">
                                                            <DoubleAnimation.EasingFunction>
                                                                <QuadraticEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ColorAnimation
                                                            Storyboard.TargetName="TaskText"
                                                            Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                                            To="#E2E2E8" Duration="0:0:0.2"/>
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="StrikeScaleT"
                                                            Storyboard.TargetProperty="ScaleX"
                                                            To="0" Duration="0:0:0.18"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter TargetName="TaskText"    Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="StrikeLine"  Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="EditDisplay" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Inline pending input row -->
                        <TextBlock x:Name="PendingText"
                                   Visibility="Collapsed"
                                   Margin="35,0,20,2"
                                   FontSize="12.5"
                                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                                   Foreground="{StaticResource TextBrush}"
                                   TextWrapping="Wrap"/>

                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- /Drawer -->

                </StackPanel>

                <!-- ── Timer ─────────────────────────────────────────────── -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Right"
                            Margin="10,2,10,6">
                    <TextBlock x:Name="LockIcon"
                               Visibility="Collapsed"
                               Text="&#xE72E;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="9"
                               Foreground="#4ADE80"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"/>
                    <TextBlock x:Name="TimerText"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                               FontSize="10.5"/>
                    <Button x:Name="RefreshBtn"
                            Visibility="Collapsed"
                            Content="&#xE149;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="9"
                            Margin="4,0,0,0"
                            Padding="0"
                            Cursor="Hand"
                            VerticalAlignment="Center"
                            Click="OnRefreshClick">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground" Value="{StaticResource SubtextBrush}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- ── Reset dots column ─────────────────────────────────── -->
                <StackPanel x:Name="ResetDotsPanel"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Right"
                            Orientation="Vertical"
                            Margin="0,34,3,0"
                            Width="6"
                            IsHitTestVisible="False"/>

                <!-- ── Close button ──────────────────────────────────────── -->
                <Button x:Name="DestroyBtn" Width="22" Height="22"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,6,6,0"
                        Content="✕" FontSize="11"
                        Cursor="Hand" Click="OnDestroyClick"
                        ToolTip="Удалить стикер">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Opacity" Value="0.35"/>
                            <Setter Property="Foreground" Value="{StaticResource SubtextBrush}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- ── Folded corner ──────────────────────────────────────── -->
                <Path
                      HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Margin="0,0,4,4"
                      Data="M0,13 L13,0 L13,13 Z"
                      IsHitTestVisible="False"
                      Opacity="0.75">
                    <Path.Fill>
                        <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                            <GradientStop Color="#13131A" Offset="0.0"/>
                            <GradientStop Color="#252533" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Path.Fill>
                    <Path.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.45"
                                          BlurRadius="4" ShadowDepth="1.5" Direction="135"/>
                    </Path.Effect>
                </Path>

                <!-- ── Outline overlay (wheel-cycled color) ──────────────── -->
                <Border x:Name="OutlineBorder"
                        CornerRadius="9"
                        Background="Transparent"
                        BorderThickness="2"
                        IsHitTestVisible="False"/>

            </Grid>
        </Border>
    </Grid>
</Window>
